# Exemplo de configuração de segredos do Streamlit.
# ---------------------------------------------------------------------------
# Copie este arquivo para .streamlit/secrets.toml (que está no .gitignore e
# NÃO deve ser commitado) e preencha com seus valores reais. No Streamlit
# Community Cloud, cole o mesmo conteúdo em: App > Settings > Secrets.

[github]
# Personal Access Token do GitHub com permissão de escrita em Contents.
#   - Fine-grained token: Repository access > este repo, com a permissão
#     "Contents: Read and write".
#   - Token clássico: escopo "repo".
token  = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Repositório no formato "owner/nome".
repo   = "LuizDomingo27/APP_Analise_Divida"

# Branch onde o banco será gravado (opcional, padrão: "main").
branch = "main"

# Caminho do banco dentro do repositório (opcional, padrão: "data/dividas.db").
path   = "data/dividas.db"
